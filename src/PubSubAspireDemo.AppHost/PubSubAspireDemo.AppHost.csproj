	<ItemGroup>
		<PackageReference Include="Aspire.Hosting.AppHost" Version="9.5.2" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\PubSubAspireDemo.Api\PubSubAspireDemo.Api.csproj" />
		<ProjectReference Include="..\PubSubAspireDemo.Worker\PubSubAspireDemo.Worker.csproj" />
	</ItemGroup>

</Project>
